# Frontend environment variables for local development
# API base URL used by the app (can be overridden by Vite with VITE_API_URL)
# 
# LOCAL: Use localhost
# VITE_API_URL=http://localhost:5000/api/v1
#
# PRODUCTION: Relative path (will use same domain) or absolute subdomain URL
# VITE_API_URL=https://csedusc-formula1.farefin.com/api/v1
#
# DEFAULT: Empty means relative path /api/v1 (recommended for deployment)
VITE_API_URL=
