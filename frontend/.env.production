# .env.production - Production environment variables for frontend
# Copy this to frontend/.env on your server

# API Base URL
# Using relative path so it works whether accessed as:
# - https://csedusc-formula1.farefin.com/ → calls https://csedusc-formula1.farefin.com/api/v1
# - Or absolute URL if needed:
VITE_API_URL=/api/v1

# Alternative (absolute URL):
# VITE_API_URL=https://csedusc-formula1.farefin.com/api/v1
