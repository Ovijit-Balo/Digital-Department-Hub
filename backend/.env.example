NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/digital_department_hub
# Optional: use a dedicated Atlas/test database when running Jest.
# TEST_MONGODB_URI=mongodb+srv://...
# PRODUCTION: Use MongoDB Atlas
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/digital_department_hub
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=1d
REFRESH_TOKEN_EXPIRES_DAYS=7
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
RUN_WORKER_WITH_API=false
ENABLE_QUEUE=true
STORAGE_PROVIDER=cloudinary
# Comma-separated list of allowed frontend origins. For local dev use http://localhost:5173
# In development you may set FRONTEND_URL=* to allow any origin (not recommended in production).
# PRODUCTION: Use your subdomain
# FRONTEND_URL=https://csedusc-formula1.farefin.com
FRONTEND_URL=http://localhost:5173,http://127.0.0.1:5173
LOG_LEVEL=info

# ---- Email (SMTP) --------------------------------------------------------
# EMAIL_FROM is the "From" address shown to recipients.
EMAIL_FROM=no-reply@departmenthub.edu
#
# Email delivery is OPTIONAL. When SMTP_USER + SMTP_PASS are set, password-reset
# and invitation emails are sent for real via nodemailer; otherwise the mailer
# falls back to logging the link to the console (fine for local development).
#
# --- Gmail setup (free, good for demos) -----------------------------------
# 1. Use a Gmail account and turn on 2-Step Verification:
#      https://myaccount.google.com/security
# 2. Create an "App Password" (NOT your normal Gmail password):
#      https://myaccount.google.com/apppasswords
#    Pick "Mail" as the app; Google gives you a 16-character password.
# 3. Fill in the values below (remove spaces from the app password), then
#    restart the backend. Set EMAIL_FROM to your Gmail address too.
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-address@gmail.com
# SMTP_PASS=your16charapppassword
# EMAIL_FROM=Digital Department Hub <your-address@gmail.com>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Reminder emails run on an in-process node-cron schedule inside the always-on
# API server. ENABLE_REMINDER_CRON toggles it; REMINDER_CRON is a 5-field cron
# expression (default: daily at 03:00 server time).
ENABLE_REMINDER_CRON=true
REMINDER_CRON=0 3 * * *
# Shared secret for the manual reminder trigger at POST/GET /api/reminders/run.
# Optional — the endpoint is a convenience for one-off runs; the node-cron
# schedule above is the primary trigger. Leave empty to disable the endpoint.
# When set, callers must send it as "Authorization: Bearer <secret>" or "x-cron-secret".
CRON_SECRET=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
AWS_S3_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
