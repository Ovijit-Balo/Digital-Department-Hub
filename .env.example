# Environment Variables for Digital Department Hub

# Node Environment
NODE_ENV=production

# Server Configuration
PORT=5000

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/digital_department_hub

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-min-16-characters
JWT_EXPIRES_IN=1d

# Redis Configuration (for queue and caching)
REDIS_HOST=your-redis-host.com
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# Cloudinary Configuration (for file uploads)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Frontend URL
FRONTEND_URL=https://your-domain.vercel.app

# Worker Configuration
RUN_WORKER_WITH_API=false
ENABLE_QUEUE=true

# Email Configuration
EMAIL_FROM=no-reply@yourdomain.edu

# Logging
LOG_LEVEL=info
